// Specialized tsconfig for type-checking js files
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "strict": false
    },
    "include": [
        "**/*.js",
        "**/*.d.ts"
    ],
    "exclude": [
        "**/build",
        "node_modules/",
        "test/",
        "**/*.test.js",
        "widgets/",
        "gulpfile.js"
    ]
}
